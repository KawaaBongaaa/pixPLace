  "description": "AI Image Generator WebApp for Telegram",
  "main": "app_modern.js",
  "type": "module",
  "scripts": {
    "start": "node dev-server.js",
    "dev": "node dev-server.js",
    "build:css": "postcss css/main.css -o css/output.css",
    "watch:css": "postcss css/main.css -o css/output.css --watch",
